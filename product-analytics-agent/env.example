# Product Analytics Agent -- Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git

# ─── New Relic ────────────────────────────────────────────────
NEW_RELIC_API_KEY=
NEW_RELIC_ACCOUNT_ID=

# ─── Snowflake ────────────────────────────────────────────────
# Account identifier found under Admin > Accounts in Snowflake
# Format: xy12345.us-east-1
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=PRODUCT_OPS_DB
SNOWFLAKE_SCHEMA=PRODUCT_ANALYTICS
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# ─── Optional ─────────────────────────────────────────────────
# Override the default pipeline server port (default: 3001)
# PORT=3001
